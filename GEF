-- Teleport / Give logic
local function giveCommand(targetPartial, itemName)
    local targetPlayer = (string.lower(targetPartial) == "me") and "me" or findPlayer(targetPartial)
    if not targetPlayer then warn("Player not found") return end
    
    local char = player.Character
    local item = findItem(itemName)
    if not char or not char.PrimaryPart or not item then warn("Item/Char not found") return end
    
    local origPos = char.PrimaryPart.CFrame
    char:SetPrimaryPartCFrame(item.CFrame + Vector3.new(0,3,0))
    task.wait(0.1)
    
    local cam = workspace.CurrentCamera
    local origCamType = cam.CameraType
    local origCamCFrame = cam.CFrame
    cam.CameraType = Enum.CameraType.Scriptable
    cam.CFrame = CFrame.new(item.Position + Vector3.new(0,2,0), item.Position)

    local loop = true
    task.spawn(function() while loop do pressKey("E") task.wait(0.1) end end)
    task.wait(0.4)
    loop = false
    
    if targetPlayer == "me" then
        cam.CameraType = origCamType
        cam.CFrame = origCamCFrame
        char:SetPrimaryPartCFrame(origPos)
    else
        char:SetPrimaryPartCFrame(targetPlayer.Character.PrimaryPart.CFrame + Vector3.new(0,3,0))
        task.wait(0.3)
        for i=1,3 do pressKey("Q") task.wait(0.5) end
        task.wait(0.2)
        char:SetPrimaryPartCFrame(origPos)
        cam.CameraType = origCamType
        cam.CFrame = origCamCFrame
    end
end

local function toCommand(targetPartial)
    local targetPlayer = findPlayer(targetPartial)
    if targetPlayer and targetPlayer.Character and targetPlayer.Character.PrimaryPart then
        player.Character:SetPrimaryPartCFrame(targetPlayer.Character.PrimaryPart.CFrame + Vector3.new(0,3,0))
    end
end

-- Build Helper
local function getBuildPosition(option)
    local char = player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return nil, nil end
    local forward = root.CFrame.LookVector
    local origin = root.Position + Vector3.new(0,-3,0)
    if option == "click" then
        local mouse = player:GetMouse()
        local clickPos = nil
        local connection; connection = mouse.Button1Down:Connect(function() clickPos = mouse.Hit.Position end)
        local start = tick()
        while tick()-start < 2 and not clickPos do task.wait(0.05) end
        connection:Disconnect()
        if clickPos then return clickPos, (clickPos - origin).Unit end
    end
    return origin, forward
end

-- Main Build Command
local function buildCommand(args)
    local buildType = string.lower(args[2] or "")
    local pos, dir = getBuildPosition(string.lower(args[3] or "front"))
    if not pos then return end
    
    local char = player.Character
    local hammer = char:FindFirstChild("Hammer")
    if not hammer then warn("No Hammer equipped") return end
    
    local part = workspace.Road:GetChildren()[33] or workspace:FindFirstChildWhichIsA("BasePart", true)
    if not part then warn("No building part found") return end
    
    local right = dir:Cross(Vector3.new(0,1,0))

    local function fire(p1, p2)
        local dist = (p1 - p2).Magnitude
        if dist < 0.1 then return end
        local steps = math.ceil(dist/11)
        for i=0, steps-1 do
            local s = p1 + (p2-p1).Unit * (i*(dist/steps))
            local e = p1 + (p2-p1).Unit * ((i+1)*(dist/steps))
            hammer.BuildPlank:FireServer(s, e, part, part, Vector3.new(0,1,0))
        end
    end

    -- ====== TOWER ======
    if buildType == "tower" then
        local size = 12  
        local height = 30
        local ladderWidth = 5 
        
        for y = 0.5, height, 0.5 do
            if y <= 8 then
                fire(pos+right*-size/2+Vector3.new(0,y,0), pos+right*-2.5+Vector3.new(0,y,0)) 
                fire(pos+right*2.5+Vector3.new(0,y,0), pos+right*size/2+Vector3.new(0,y,0))  
            else
                fire(pos+right*-size/2+Vector3.new(0,y,0), pos+right*size/2+Vector3.new(0,y,0))
            end
            fire(pos+right*-size/2+dir*size+Vector3.new(0,y,0), pos+right*size/2+dir*size+Vector3.new(0,y,0)) 
            fire(pos+right*-size/2+Vector3.new(0,y,0), pos+right*-size/2+dir*size+Vector3.new(0,y,0)) 
            fire(pos+right*size/2+Vector3.new(0,y,0), pos+right*size/2+dir*size+Vector3.new(0,y,0)) 
        end

        for y = 1.2, height, 1.2 do 
            local p1 = pos + right*-(ladderWidth/2) + dir*(size * 0.85) + Vector3.new(0, y, 0)
            local p2 = pos + right*(ladderWidth/2) + dir*(size * 0.85) + Vector3.new(0, y, 0)
            fire(p1, p2)
        end

        for x = -size/2, size/2, 1.5 do
            if math.abs(x) < ladderWidth/2 + 1.5 then 
                fire(pos + right*x + Vector3.new(0, height+0.5, 0), pos + right*x + dir*(size*0.5) + Vector3.new(0, height+0.5, 0))
            else
                fire(pos + right*x + Vector3.new(0, height+0.5, 0), pos + right*x + dir*size + Vector3.new(0, height+0.5, 0))
            end
        end

        for y = height+1, height+3.5, 0.5 do
            fire(pos+right*-size/2+Vector3.new(0,y,0), pos+right*size/2+Vector3.new(0,y,0))
            fire(pos+right*-size/2+dir*size+Vector3.new(0,y,0), pos+right*size/2+dir*size+Vector3.new(0,y,0))
            fire(pos+right*-size/2+Vector3.new(0,y,0), pos+right*-size/2+dir*size+Vector3.new(0,y,0))
            fire(pos+right*size/2+Vector3.new(0,y,0), pos+right*size/2+dir*size+Vector3.new(0,y,0))
        end

    -- ====== HUT ======
    elseif buildType == "hut" then
        for y = 0.5,7,0.5 do
            if y<1 or y>5.5 then 
                fire(pos+right*-6+Vector3.new(0,y,0), pos+right*6+Vector3.new(0,y,0))
            else 
                fire(pos+right*-6+Vector3.new(0,y,0), pos+right*-2+Vector3.new(0,y,0)) 
                fire(pos+right*2+Vector3.new(0,y,0), pos+right*6+Vector3.new(0,y,0)) 
            end
        end
        for y=0.5,7,0.5 do fire(pos+right*6+Vector3.new(0,y,0), pos+right*6+dir*12+Vector3.new(0,y,0)) end
        for y=0.5,7,0.5 do fire(pos+right*-6+dir*12+Vector3.new(0,y,0), pos+right*6+dir*12+Vector3.new(0,y,0)) end
        for y=0.5,7,0.5 do fire(pos+right*-6+Vector3.new(0,y,0), pos+right*-6+dir*12+Vector3.new(0,y,0)) end
        for z=0,12,2 do fire(pos+right*-6+Vector3.new(0,7.5,0)+dir*z, pos+right*6+Vector3.new(0,7.5,0)+dir*z) end

    -- ====== WALL ======
    elseif buildType == "wall" then
        for y=0.5,6,0.5 do fire(pos+right*-6+Vector3.new(0,y,0), pos+right*6+Vector3.new(0,y,0)) end

    -- ====== FLOOR ======
    elseif buildType == "floor" then
        for x=-6,5.5,0.5 do fire(pos+right*x+dir*-6+Vector3.new(0,0.25,0), pos+right*x+dir*6+Vector3.new(0,0.25,0)) end

    -- ====== BIG HOUSE ======
    elseif buildType == "big-house" or buildType == "bighouse" then
        local size = 60
        local height = 16
        local corners = {pos+right*-size/2, pos+right*size/2, pos+right*size/2+dir*size, pos+right*-size/2+dir*size}
        local function wallFunc(p1,p2,h,door)
            for y=0.5,h,0.5 do
                if door and y<=8 then
                    local mid = (p1+p2)/2
                    local dLine = (p2-p1).Unit
                    fire(p1+Vector3.new(0,y,0), (mid-dLine*2.5)+Vector3.new(0,y,0))
                    fire((mid+dLine*2.5)+Vector3.new(0,y,0), p2+Vector3.new(0,y,0))
                else 
                    fire(p1+Vector3.new(0,y,0), p2+Vector3.new(0,y,0)) 
                end
            end
        end
        wallFunc(corners[1], corners[2], height, true)
        wallFunc(corners[2], corners[3], height, false)
        wallFunc(corners[3], corners[4], height, false)
        wallFunc(corners[4], corners[1], height, false)
        for z=0,size,2 do fire(pos+right*-size/2+dir*z+Vector3.new(0,height+0.5,0), pos+right*size/2+dir*z+Vector3.new(0,height+0.5,0)) end
        for z=0,size,2 do fire(pos+right*-size/2+dir*z+Vector3.new(0,0.25,0), pos+right*size/2+dir*z+Vector3.new(0,0.25,0)) end

    else
        warn("Unknown build type")
    end
end

-- Execution logic
local function parseCommand(cmd)
    local args = {}
    for word in string.gmatch(cmd,"%S+") do table.insert(args,word) end
    if #args==0 then return end
    local c = string.lower(args[1])
    
    if c == "give" and #args == 3 then 
        giveCommand(args[2], args[3])
    elseif c == "to" and #args == 2 then 
        toCommand(args[2])
    elseif c == "cmds" or c == "commands" then 
        createCommandList()
    elseif c == "build" then 
        buildCommand(args) 
    else
        print("Unknown command")
    end
end

