-- Simulation helpers
local function pressKey(key)
    local keyCode = Enum.KeyCode[key]
    if keyCode then
        VirtualInputManager:SendKeyEvent(true,keyCode,false,game)
        task.wait(0.1)
        VirtualInputManager:SendKeyEvent(false,keyCode,false,game)
    end
end

local function findPlayer(partial)
    local matches = {}
    for _,p in pairs(Players:GetPlayers()) do
        if string.find(string.lower(p.Name), string.lower(partial)) then table.insert(matches, p) end
    end
    return #matches > 0 and matches[math.random(1,#matches)] or nil
end

local function findItem(partial)
    for _,obj in pairs(Workspace:GetDescendants()) do
        if obj:IsA("BasePart") and string.find(string.lower(obj.Name), string.lower(partial)) then return obj end
    end
    return nil
end

