local function styleTextBox(box, placeholder, defaultText, pos)
    box.Size = UDim2.new(0.85, 0, 0, 35)
    box.Position = pos
    box.PlaceholderText = placeholder
    box.Text = defaultText
    box.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    box.TextColor3 = Color3.fromRGB(255, 255, 255)
    box.BorderSizePixel = 0
    box.Parent = ContentFrame
end

styleTextBox(Arg1Input, "參數 1", "Retro", UDim2.new(0.075, 0, 0.1, 0))
styleTextBox(Arg2Input, "參數 2", "Tags", UDim2.new(0.075, 0, 0.4, 0))

